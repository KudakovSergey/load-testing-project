{
  "request": {
    "method": "POST",
    "url": "/api/users"
  },
  "response": {
    "status": 201,
    "jsonBody": {
      "id": 1,
      "username": "{{jsonPath request.body '$.username'}}",
      "email": "{{jsonPath request.body '$.email'}}",
      "message": "User created"
    },
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"]
  }
}
